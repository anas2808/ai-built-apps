<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Retro Portfolio - Anas Mansuri</title>
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="container">
        <header>
            <div class="profile-header">
                <img src="images/profile.jpg" alt="Anas Mansuri Profile Picture" class="profile-pic">
                <div class="header-text">
                    <h1>Anas Mansuri</h1>
                    <p class="bio">Motivated MCA student and aspiring software developer</p>
                    <ul class="contact-info">
                        <li>Ahmedabad, Gujarat, India</li>
                        <li>7990238770</li>
                        <li>anas2808anas@gmail.com</li>
                        <li><a href="https://www.linkedin.com/in/your-linkedin-profile" target="_blank">LinkedIn</a></li>
                        <li><a href="https://github.com/your-github-profile" target="_blank">GitHub</a></li>
                        <li>Portfolio: <a href="https://your-portfolio-link.com" target="_blank">your-portfolio-link.com</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <nav>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#experience">Experience</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>

        <main>
            <section id="home">
                <h2>Career Objective</h2>
                <p>Motivated MCA student and aspiring software developer seeking an entry-level opportunity where I can apply my skills in web development, automation, and problem-solving to build real-world solutions while continuously learning and growing in a professional environment.</p>
            </section>

            <section id="education">
                <h2>Education</h2>
                <div class="education-item">
                    <h3>Master of Computer Applications (MCA)</h3>
                    <p>LJ Institute of Computer Application | 2025 - 2027</p>
                </div>
                <div class="education-item">
                    <h3>Bachelor of Computer Applications (BCA)</h3>
                    <p>LJ Institute of Computer Application | 2022 - 2025 | CGPA: 7.08</p>
                </div>
                <div class="education-item">
                    <h3>Higher Secondary (XII)</h3>
                    <p>Ankur High School (GSEB) | 2022 | Percentage: 55.6%</p>
                </div>
                <div class="education-item">
                    <h3>Secondary (X)</h3>
                    <p>Model English School | 2020 | Percentage: 51.67%</p>
                </div>
            </section>

            <section id="skills">
                <h2>Technical Skills</h2>
                <div class="skills-category">
                    <h3>Programming Languages:</h3>
