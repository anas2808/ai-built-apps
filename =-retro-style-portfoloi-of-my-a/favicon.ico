<!-- Content of style.css -->
:root {
    --primary-color: #4A90E2;
    --secondary-color: #D9E4F5;
    --background-color: #FFFFFF;
    --text-color: #333333;
    --footer-background: #333333;
    --footer-text-color: #FFFFFF;
    --header-background: #f8f8f8;
    --navbar-text-color: #333333;
    --navbar-hover-color: #4A90E2;
    --section-background: #f4f4f4;
    --card-background: #ffffff;
    --border-color: #cccccc;
    --button-background: #4A90E2;
    --button-text-color: #ffffff;
}

body {
    font-family: 'Courier New', Courier, monospace;
    margin: 0;
    padding: 0;
    background-color: var(--background-color);
    color: var(--text-color);
    line-height: 1.6;
}

.container {
    width: 80%;
    margin: auto;
    overflow: hidden;
    padding: 0 20px;
}

/* Header Styling */
header {
    background-color: var(--header-background);
    padding-top: 10px;
    min-height: 70px;
    border-bottom: var(--primary-color) 3px solid;
}

header h1 {
    margin: 0;
    color: var(--primary-color);
    text-align: left;
    font-size: 24px;
}

header nav {
    float: right;
    margin-top: 10px;
}

header ul {
    margin: 0;
    padding: 0;
    list-style: none;
}

header li {
    display: inline;
    margin-left: 20px;
}

header a {
    color: var(--navbar-text-color);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 16px;
    transition: color 0.3s ease;
}

header a:hover {
    color: var(--navbar-hover-color);
}

/* Hero Section Styling */
.hero-section {
    background-color: var(--secondary-color);
    padding: 80px 0;
    text-align: center;
    position: relative;
    overflow: hidden;
}

.hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: url('data:image/svg+xml;base64,');
    background-repeat: no-repeat;
    background-size: cover;
    opacity: 0.2;
    z-index: 0;
}

.hero-content {
    position: relative;
    z-index: 1;
}

.profile-pic {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    margin-bottom: 20px;
    border: 4px solid var(--primary-color);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    object-fit: cover;
}

.hero-section h2 {
    font-size: 32px;
    margin-bottom: 10px;
    color: var(--primary-color);
}

.hero-section p {
    font-size: 18px;
    margin-bottom: 5px;
}

.social-links a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: bold;
    margin: 0 5px;
}

.social-links a:hover {
    text-decoration: underline;
}

/* General Section Styling */
section {
    padding: 50px 0;
    background-color: var(--background-color);
}

section:nth-of-type(even) {
    background-color: var(--section-background);
}

section h2 {
    text-align: center;
    color: var(--primary-color);
    margin-bottom: 30px;
    font-size: 28px;
    border-bottom: 2px solid var(--primary-color);
    display: inline-block;
    padding-bottom: 5px;
}

/* About Section */
#about p {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    font-size: 16px;
    color: var(--text-color);
}

/* Education Section */
.education-item {
    margin-bottom: 20px;
    padding: 15px;
    background-color: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 5px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.education-item h3 {
    margin-top: 0;
    color: var(--primary-color);
    font-size: 20px;
}

.education-item p {
    margin-bottom: 0;
    font-size: 16px;
    color: var(--text-color);
}

/* Skills Section */
.skills-group {
    margin-bottom: 15px;
}

.skills-group h3 {
    color: var(--primary-color);
    margin-bottom: 5px;
    font-size: 18px;
}

.skills-group p {
    font-size: 16px;
    color: var(--text-color);
}

/* Experience Section */
.experience-item {
    margin-bottom: 20px;
    padding: 15px;
    background-color: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 5px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.experience-item h3 {
    margin-top: 0;
    color: var(--primary-color);
    font-size: 20px;
    margin-bottom: 5px;
}

.experience-item p {
    font-size: 16px;
    color: var(--text-color);
    margin-bottom: 10px;
}

.experience-item ul {
    margin-left: 20px;
    font-size: 15px;
    color: var(--text-color);
}

.experience-item li {
    margin-bottom: 5px;
}

/* Projects Section */
.project-item {
    margin-bottom: 25px;
    padding: 20px;
    background-color: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.project-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0,0,0,0.15);
}

.project-item h3 {
    margin-top: 0;
    color: var(--primary-color);
    font-size: 22px;
    margin-bottom: 10px;
}

.project-item p {
    font-size: 16px;
    color: var(--text-color);
    margin-bottom: 10px;
}

.project-item a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: bold;
    display: inline-block;
    margin-top: 10px;
}

.project-item a:hover {
    text-decoration: underline;
}

/* Certifications Section */
.certification-item {
    margin-bottom: 20px;
    padding: 15px;
    background-color: var(--card-background);
    border: 1px solid var(--border-color);
    border-radius: 5px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.certification-item h3 {
    margin-top: 0;
    color: var(--primary-color);
    font-size: 20px;
    margin-bottom: 5px;
}

.certification-item p {
    font-size: 16px;
    color: var(--text-color);
    margin-bottom: 5px;
}

/* Languages Section */
#languages p {
    text-align: center;
    font-size: 18px;
    color: var(--text-color);
}

/* Contact Section */
#contact {
    text-align: center;
}

#contact p {
    font-size: 16px;
    margin-bottom: 10px;
}

.contact-links a {
    color: var(--primary-color);
    text-decoration: none;
    font-weight: bold;
    margin: 0 10px;
}

.contact-links a:hover {
    text-decoration: underline;
}

/* Footer Styling */
footer {
    background-color: var(--footer-background);
    color: var(--footer-text-color);
    text-align: center;
    padding: 20px 0;
    margin-top: 30px;
}

/* Responsive Design */
@media (max-width: 768px) {
    header {
        padding-top: 15px;
        min-height: auto;
        text-align: center;
    }

    header #branding {
        float: none;
        margin-bottom: 10px;
    }

    header nav {
        float: none;
        margin-top: 0;
        width: 100%;
    }

    header ul {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        padding: 0;
    }

    header li {
        margin: 5px 10px;
        display: inline-block;
    }

    .container {
        width: 95%;
        padding: 0 10px;
    }

    .hero-section {
        padding: 60px 0;
    }

    .hero-section h2 {
        font-size: 28px;
    }

    section h2 {
        font-size: 24px;
    }

    .profile-pic {
        width: 120px;
        height: 120px;
    }
}

@media (max-width: 480px) {
    header h1 {
        font-size: 20px;
    }

    header a {
        font-size: 14px;
    }

    header li {
        margin: 5px 5px;
    }

    .hero-section h2 {
        font-size: 24px;
    }

    .hero-section p {
        font-size: 16px;
    }

    section h2 {
        font-size: 22px;
    }

    .education-item, .experience-item, .project-item, .certification-item {
        padding: 15px;
    }

    .project-item h3, .experience-item h3, .education-item h3, .certification-item h3 {
        font-size: 18px;
    }
    
    .education-item p, .experience-item p, .project-item p, .certification-item p {
        font-size: 14px;
    }

     .skills-group h3 {
        font-size: 16px;
    }

    .skills-group p {
        font-size: 14px;
    }
}

<!-- Content of script.js -->
document.addEventListener('DOMContentLoaded', function() {
    // Smooth scrolling for anchor links
    document.querySelectorAll('nav a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();

            const targetId = this.getAttribute('href');
            const targetElement = document.querySelector(targetId);

            if (targetElement) {
                targetElement.scrollIntoView({
                    behavior: 'smooth'
                });
            }
        });
    });

    // Optional: Add a subtle animation for elements when they enter the viewport
    const sections = document.querySelectorAll('section');
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    sections.forEach(section => {
        observer.observe(section);
    });

    // Add CSS class for visible sections for fade-in effect
    const style = document.createElement('style');
    style.innerHTML = `
        section.is-visible {
            animation: fadeIn 0.8s ease-out forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    `;
    document.head.appendChild(style);
});
